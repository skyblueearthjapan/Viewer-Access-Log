{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Urls": "http://localhost:5099",

  "DataMode": "Sample",

  "//": "本番(P3/P4a)で使う接続情報のテンプレート。実値は appsettings.Production.json に置きコミットしない。",
  "Sources": {
    "AuditPostgres": "Host=192.168.1.242;Port=5432;Database=audit_logger;Username=viewer;Password=__SET_IN_LOCAL__;Search Path=audit",
    "SfeSqlite": "Data Source=__SFE_ACCESS_LOG.db__;Mode=ReadOnly;Cache=Shared",
    "TargetFolderRegex": "[\\\\/]Data[\\\\/]技術部([\\\\/]|$)"
  },

  "Live": {
    "AuditPg": {
      "ConnectionString": "Host=192.168.1.242;Port=5432;Database=audit_logger;Username=viewer;Password=__SET_IN_PRODUCTION__;Search Path=audit",
      "Schema": "audit"
    },
    "ConfigPg": {
      "ConnectionString": "Host=192.168.1.242;Port=5432;Database=audit_logger;Username=config_editor;Password=__SET_IN_PRODUCTION__;Search Path=audit",
      "Schema": "audit"
    },
    "SfeSqlitePath": "__PATH_TO_SFE_catalog.db__",
    "CachePath": "cache.db",
    "Dept": "技術部",
    "SyncIntervalSeconds": 300,
    "LookbackDays": 30
  }
}
