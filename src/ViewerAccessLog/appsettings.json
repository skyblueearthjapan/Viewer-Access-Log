{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Urls": "http://localhost:5099",

  "DataMode": "Sample",

  "//": "本番(P3)で使う接続情報のテンプレート。実値は appsettings.Local.json に置きコミットしない。",
  "Sources": {
    "AuditPostgres": "Host=192.168.1.242;Port=5432;Database=audit_logger;Username=viewer;Password=__SET_IN_LOCAL__;Search Path=audit",
    "SfeSqlite": "Data Source=__SFE_ACCESS_LOG.db__;Mode=ReadOnly;Cache=Shared",
    "TargetFolderRegex": "[\\\\/]Data[\\\\/]技術部([\\\\/]|$)"
  }
}
